# AAC Customer Portal — Environment Configuration
# Copy to .env and fill in values.
#
# Notes for operators:
#   - Hosts (PG_HOST etc.) have NO production defaults in code — the
#     app starts pointing at localhost unless you set them here.
#   - SECRET_KEY is REQUIRED. The app refuses to start without it
#     (no fallback to a well-known default).
#   - AAP_VERIFY_SSL defaults to TRUE. Set it to false only if your
#     AAP controller serves a self-signed certificate AND you have
#     accepted the MITM risk in your environment.

# PostgreSQL (read-only compliance_reader user)
PG_HOST=
PG_PORT=5432
PG_DATABASE=compliance
PG_USER=compliance_reader
PG_PASSWORD=

# PostgreSQL (portal's own DB — tenants, policies, bundles, baselines)
PORTAL_PG_HOST=
PORTAL_PG_PORT=5432
PORTAL_PG_DATABASE=aac_portal
PORTAL_PG_USER=aac_portal_app
PORTAL_PG_PASSWORD=

# AAP Controller
AAP_URL=
AAP_TOKEN=
AAP_VERIFY_SSL=true

# OPA
OPA_SECURITY_URL=http://localhost:8181
OPA_COMPLIANCE_URL=http://localhost:8182
OPA_OT_URL=http://localhost:8183

# Portal (SECRET_KEY: generate with `python -c 'import secrets; print(secrets.token_urlsafe(48))'`)
SECRET_KEY=
PORTAL_ADMIN_TOKEN=
ALLOWED_ORIGINS=http://localhost:3000
DEBUG=false

# Rate limiting (slowapi). Default applies per-client-IP across every
# endpoint; tighter per-route limits are baked into the auth handlers.
# Leave RATE_LIMIT_STORAGE_URI empty for in-process counters; set to a
# redis:// URI when running multiple workers so counters are shared.
RATE_LIMIT_DEFAULT=200/minute
RATE_LIMIT_STORAGE_URI=
