# AAC Customer Portal — Environment Configuration
# Copy to .env and fill in values

# PostgreSQL (read-only compliance_reader user)
PG_HOST=192.168.4.62
PG_PORT=5432
PG_DATABASE=compliance
PG_USER=compliance_reader
PG_PASSWORD=

# AAP Controller
AAP_URL=https://192.168.4.62
AAP_TOKEN=
AAP_VERIFY_SSL=false

# OPA
OPA_SECURITY_URL=http://192.168.4.62:8181
OPA_COMPLIANCE_URL=http://192.168.4.62:8182
OPA_OT_URL=http://192.168.4.62:8183

# Portal
SECRET_KEY=change-me-in-production
ALLOWED_ORIGINS=http://localhost:3000
DEBUG=false

# Logging
#   LOG_LEVEL: debug | info | warning | error | critical
#   LOG_FORMAT: json (structured for aggregators) | plain (human-readable dev)
LOG_LEVEL=info
LOG_FORMAT=json
